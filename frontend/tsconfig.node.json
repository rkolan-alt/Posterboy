{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    // Composite projects must emit. Left at the default, the output lands as
    // vite.config.js beside vite.config.ts, and Vite resolves .js ahead of .ts,
    // so a stale compiled config would silently shadow the real one.
    "outDir": "./node_modules/.tmp",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo"
  },
  "include": ["vite.config.ts"]
}
