# Spotify OAuth
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/api/auth/callback

# Session & Security
SESSION_SECRET=generate-a-random-secure-string-here
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Frontend
FRONTEND_URL=http://127.0.0.1:5173

# Database
DATABASE_URL=postgresql://posterboy_user:posterboy_pass@postgres:5432/posterboy
